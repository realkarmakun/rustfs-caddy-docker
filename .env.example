# Domains — must point to this server's IP before starting
RUSTFS_S3_DOMAIN=s3.example.com
RUSTFS_CONSOLE_DOMAIN=s3-console.example.com

# Your real email address — used by Let's Encrypt for cert expiry notices
# Must NOT be an @example.com address or Let's Encrypt will reject it
ACME_EMAIL=you@yourdomain.com

# RustFS credentials
RUSTFS_ACCESS_KEY=minioadmin
RUSTFS_SECRET_KEY=minioadmin
